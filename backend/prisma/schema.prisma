generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model login_test {
  id       Int    @id @default(autoincrement())
  email    String @db.VarChar(100)
  password String @db.VarChar(255)
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password      String
}