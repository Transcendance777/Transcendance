# Base de données
DB_USER=
DB_PASS=
DB_NAME=
DB_HOST=postgres
DB_PORT=5432

DATABASE_URL=postgresql://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# Twitch API
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Grafana - accès admin
GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=
GF_AUTH_ANONYMOUS_ENABLED=false

# Grafana - reverse proxy via nginx
GF_SERVER_ROOT_URL=https://localhost:8443/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true

# Postgres exporter
DATA_SOURCE_URI=postgres:5432/${DB_NAME}?sslmode=disable
DATA_SOURCE_USER=${DB_USER}
DATA_SOURCE_PASS=${DB_PASS}

# WAF (ModSecurity)
WAF_BACKEND=http://nginx:80
WAF_RULE_ENGINE=On
WAF_PARANOIA=2
WAF_ANOMALY_INBOUND=5
WAF_ANOMALY_OUTBOUND=4
WAF_BLOCKING_PARANOIA=2
WAF_PORT=8080
WAF_TIMEOUT=60
WAF_DNS_SERVER=127.0.0.11
PROXY_SSL=on                          # Active la terminaison HTTPS sur le WAF
PROXY_SSL_CERT=/etc/waf/certs/cert.crt   # Chemin du certificat SSL dans le conteneur
PROXY_SSL_CERT_KEY=/etc/waf/certs/key.key # Chemin de la clé privée SSL dans le conteneur
WAF_SSL_PORT=8443
